# ChrispyMPS — .env.example
# Copia questo file in .env.local e compila i valori reali.
# NON committare mai .env.local su GitHub.

# ===== SUPABASE =====
# Trovate su: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://PROGETTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ===== RESEND (email) =====
# https://resend.com → API Keys
RESEND_API_KEY=re_...

# ===== MAILERLITE (newsletter) =====
# https://dashboard.mailerlite.com → Integrations → API
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=   # ID del gruppo "Mappe" — trovalo in Groups

# ===== ADMIN =====
# Password per accedere a /admin — scegli una password robusta
ADMIN_PASSWORD=scegli-una-password-sicura
# Stringa random per firmare i cookie e i token email (min 32 caratteri)
ADMIN_SECRET=stringa-random-minimo-32-caratteri-qui

# ===== SITO =====
NEXT_PUBLIC_SITE_URL=https://chrispybmx.com
